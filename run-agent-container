set -x

NO_NETWORK=false
for arg in "$@"; do
    case "$arg" in
        --no-network) NO_NETWORK=true ;;
    esac
done

PROJECT_NAME="$(basename "$(pwd)")"
AGENT_CONTAINER_RESOURCES="${HOME}/agent-container-resources"

# Check whether a container with this project name already exists
CONTAINER_EXISTS=$(docker ps -a --filter "name=^${PROJECT_NAME}$" --format '{{.Names}}')

if [ -z "$CONTAINER_EXISTS" ]; then
    # First run: create the container (does not start it)
    DOCKER_CREATE_ARGS=(
        --name "${PROJECT_NAME}"
    )
    if [ "$NO_NETWORK" = true ]; then
        DOCKER_CREATE_ARGS+=(--network=none)
    fi
    docker create "${DOCKER_CREATE_ARGS[@]}" \
          --cap-drop=ALL \
          --cap-add=CHOWN \
          --cap-add=DAC_OVERRIDE \
          --cap-add=FOWNER \
          --cap-add=FSETID \
          --cap-add=SETFCAP \
          --cap-add=SETUID \
          --cap-add=SETGID \
          --security-opt=no-new-privileges \
          --memory=16g \
          --pids-limit=512 \
          -e "TAVILY_API_KEY=$(security find-generic-password -s travily-api-key -a travily-api-key -w)" \
          -e "JUKKA_OPENAI_API_KEY=$(security find-generic-password -s 'jukka-openai-api-key' -a 'jukka-openai-api-key' -w)" \
          -e "JUKKA_HUGGINGFACE_API_KEY=$(security find-generic-password -s 'jukka-huggingface-api-key' -a 'jukka-huggingface-api-key' -w)" \
          -e "JUKKA_OPENROUTER_API_KEY=$(security find-generic-password -s 'jukka-openrouter-api-key' -a 'jukka-openrouter-api-key' -w)" \
          -v "$(pwd):/workspace" \
          -w /workspace \
          agent-container:latest

    docker cp "${AGENT_CONTAINER_RESOURCES}/settings.json" "${PROJECT_NAME}:/root/.pi/agent/"
fi

# Start the container (creates if not exists above, reuses if it does)
docker start "${PROJECT_NAME}" 2>/dev/null || true
docker cp "${AGENT_CONTAINER_RESOURCES}/AGENTS.md" "${PROJECT_NAME}:/root/.pi/agent/"
docker cp "${AGENT_CONTAINER_RESOURCES}/models.json" "${PROJECT_NAME}:/root/.pi/agent/"

# Copy all skill directories into the container
for skill in "${AGENT_CONTAINER_RESOURCES}/skills/"*; do
    [ -e "$skill" ] || continue
    skill_name="$(basename "$skill")"
    docker cp "$skill" "${PROJECT_NAME}:/root/.pi/agent/skills/${skill_name}"
done

docker exec "${PROJECT_NAME}" touch /root/this-is-an-agent-container

docker exec -it --detach-keys="ctrl-z,z" "${PROJECT_NAME}" bash
docker stop "${PROJECT_NAME}" 2>/dev/null || true
